# ─────────────────────────────────────────────────────────────────────────────
# RWA Infinity Model — API Keys Configuration
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file to .env  (never commit .env to git)
#   2. Fill in the keys you have — all keys are OPTIONAL
#   3. The app runs on free-tier / public endpoints without any keys
#   4. Keys unlock higher rate limits, more data, and premium features
#
# Windows PowerShell:  $env:RWA_COINGECKO_API_KEY = "your_key"
# Windows CMD:         set RWA_COINGECKO_API_KEY=your_key
# Linux/Mac:           export RWA_COINGECKO_API_KEY="your_key"
# .env file (python-dotenv): just paste below without 'export'
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # anthropic.com — required for AI analysis

# ── Price & Market Data ───────────────────────────────────────────────────────
RWA_COINGECKO_API_KEY=               # coingecko.com/en/api — Pro: 500 calls/min vs 30/min free
RWA_COINMARKETCAP_API_KEY=           # coinmarketcap.com/api — Basic free tier available
RWA_TIINGO_API_KEY=                  # tiingo.com — stocks, ETFs, crypto EOD + intraday
RWA_ALPHA_VANTAGE_API_KEY=           # alphavantage.co — 25 calls/day free, 75/min premium
RWA_FRED_API_KEY=                    # fred.stlouisfed.org — free, just increases limits
RWA_MESSARI_API_KEY=                 # messari.io — crypto fundamentals research
RWA_NANSEN_API_KEY=                  # nansen.ai — on-chain analytics (paid)
RWA_DUNE_API_KEY=                    # dune.com — on-chain SQL analytics
RWA_MORALIS_API_KEY=                 # moralis.io — cross-chain data
RWA_KAIKO_API_KEY=                   # kaiko.com — institutional order book data (paid)
RWA_COIN_METRICS_API_KEY=            # coinmetrics.io — network data

# ── Block Explorers ───────────────────────────────────────────────────────────
RWA_ETHERSCAN_API_KEY=               # etherscan.io — free tier available
RWA_POLYGONSCAN_API_KEY=             # polygonscan.com — same key as Etherscan
RWA_ARBISCAN_API_KEY=                # arbiscan.io — Arbitrum explorer
RWA_BSCSCAN_API_KEY=                 # bscscan.com — BNB Chain explorer
RWA_OPTIMISTIC_API_KEY=              # optimistic.etherscan.io — Optimism
RWA_BASESCAN_API_KEY=                # basescan.org — Base L2
RWA_SNOWTRACE_API_KEY=               # snowtrace.io — Avalanche
RWA_SOLSCAN_API_KEY=                 # solscan.io — Solana explorer

# ── Web3 Node Providers ───────────────────────────────────────────────────────
RWA_ALCHEMY_API_KEY=                 # alchemy.com — 300M compute units/month free
RWA_INFURA_API_KEY=                  # infura.io — 100K requests/day free
RWA_HELIUS_API_KEY=                  # helius.dev — Solana RPC (100K credits/month free)
RWA_QUICKNODE_API_KEY=               # quicknode.com — multi-chain RPC
RWA_THE_GRAPH_API_KEY=               # thegraph.com — DeFi subgraph queries

# ── CEX Exchange APIs (read-only — for price/volume data) ────────────────────
RWA_BINANCE_API_KEY=                 # binance.com — public market data (no key needed for prices)
RWA_BINANCE_API_SECRET=
RWA_COINBASE_API_KEY=                # coinbase.com/advanced-trade — Advanced Trade API
RWA_COINBASE_API_SECRET=
RWA_KRAKEN_API_KEY=                  # kraken.com
RWA_KRAKEN_API_SECRET=
RWA_OKX_API_KEY=                     # okx.com
RWA_OKX_API_SECRET=
RWA_BYBIT_API_KEY=                   # bybit.com
RWA_BYBIT_API_SECRET=
RWA_KUCOIN_API_KEY=                  # kucoin.com
RWA_KUCOIN_API_SECRET=
RWA_KUCOIN_API_PASSPHRASE=
RWA_GATE_IO_API_KEY=                 # gate.io
RWA_GATE_IO_API_SECRET=
RWA_DERIBIT_API_KEY=                 # deribit.com — options/futures
RWA_DERIBIT_API_SECRET=

# ── DEX / DeFi APIs ───────────────────────────────────────────────────────────
RWA_DYDX_API_KEY=                    # dydx.exchange — perpetuals
RWA_DYDX_API_SECRET=
RWA_DYDX_PASSPHRASE=
