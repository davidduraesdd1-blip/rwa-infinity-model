RWA_PROPY_API_KEY=                   # propy.com — RE title and escrow
RWA_MANTRA_API_KEY=                  # mantrachain.io
RWA_PLUME_API_KEY=                   # plumenetwork.xyz

# ── News & Sentiment ──────────────────────────────────────────────────────────
RWA_NEWSAPI_API_KEY=                 # newsapi.org — 100 req/day free, $449/mo developer
RWA_CRYPTOPANIC_API_KEY=             # cryptopanic.com — free tier available
RWA_TWITTER_BEARER_TOKEN=            # developer.twitter.com — v2 API bearer token
RWA_REDDIT_CLIENT_ID=                # reddit.com/prefs/apps
RWA_REDDIT_CLIENT_SECRET=
RWA_LUNARCRUSH_API_KEY=              # lunarcrush.com — social analytics
RWA_SANTIMENT_API_KEY=               # santiment.net — on-chain + social signals

# ── Notifications (optional) ──────────────────────────────────────────────────
RWA_TELEGRAM_BOT_TOKEN=              # Create via @BotFather on Telegram
RWA_TELEGRAM_CHAT_ID=                # Your chat/channel ID
RWA_DISCORD_WEBHOOK_URL=             # Server Settings > Integrations > Webhooks
RWA_SMTP_HOST=smtp.gmail.com
RWA_SMTP_PORT=587
RWA_SMTP_USER=                       # Gmail/SMTP username
RWA_SMTP_PASSWORD=                   # App password (not account password)
RWA_ALERT_EMAIL=                     # Destination email for price/yield alerts
