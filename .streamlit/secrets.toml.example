# .streamlit/secrets.toml.example
# Copy this file to .streamlit/secrets.toml and fill in your keys.
# secrets.toml is gitignored — never commit the real file.
#
# Key rotation tiers:
#   Tier 1 (critical — rotate immediately if leaked): ANTHROPIC_API_KEY
#   Tier 2 (high — rotate within 24h): RWA_SENTRY_DSN, ALCHEMY_API_KEY, THE_GRAPH_API_KEY
#   Tier 3 (medium — rotate within 1 week): COINGECKO_API_KEY, FRED_API_KEY, ETHERSCAN_API_KEY
#   Tier 4 (low — rotate at next cycle): all others

# ─── Tier 1: AI / LLM ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY = ""          # https://console.anthropic.com/

# ─── Tier 2: Infrastructure ───────────────────────────────────────────────────
RWA_SENTRY_DSN = ""             # https://sentry.io/  (free tier)
ALCHEMY_API_KEY = ""            # https://www.alchemy.com/
INFURA_API_KEY = ""             # https://infura.io/
THE_GRAPH_API_KEY = ""          # https://thegraph.com/studio/

# ─── Tier 3: Market Data ──────────────────────────────────────────────────────
RWA_COINGECKO_API_KEY = ""      # https://www.coingecko.com/en/api  (Pro)
FRED_API_KEY = ""               # https://fred.stlouisfed.org/docs/api/api_key.html  (free)
ETHERSCAN_API_KEY = ""          # https://etherscan.io/apis  (free tier)
POLYGONSCAN_API_KEY = ""        # https://polygonscan.com/apis

# ─── Tier 4: Optional / Web3 ─────────────────────────────────────────────────
CENTRIFUGE_API_KEY = ""
MAPLE_API_KEY = ""
ONDO_API_KEY = ""
PENDLE_API_KEY = ""
CDP_API_KEY_ID = ""
CDP_API_KEY_SECRET = ""
XRPL_NODE_URL = ""              # e.g. wss://xrplcluster.com
CRYPTOPANIC_API_KEY = ""        # https://cryptopanic.com/developers/api/
